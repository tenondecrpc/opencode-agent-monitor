{
  "name": "opencode-agent-monitor",
  "version": "1.0.9",
  "description": "Monitor, audit, and analyze agent/subagent routing and tool usage in OpenCode sessions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "agent",
    "monitoring",
    "routing",
    "audit",
    "observability",
    "ai-agent"
  ],
  "author": "tenonde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tenondecrpc/opencode-agent-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/tenondecrpc/opencode-agent-monitor/issues"
  },
  "homepage": "https://github.com/tenondecrpc/opencode-agent-monitor#readme",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
