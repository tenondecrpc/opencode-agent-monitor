{
  "name": "opencode-agent-monitor",
  "version": "1.0.17",
  "description": "Monitor, audit, and analyze agent/subagent routing and tool usage in OpenCode sessions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./exports": {
      "types": "./dist/exports.d.ts",
      "import": "./dist/exports.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "agent",
    "monitoring",
    "routing",
    "audit",
    "observability",
    "ai-agent"
  ],
  "author": "tenonde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tenondecrpc/opencode-agent-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/tenondecrpc/opencode-agent-monitor/issues"
  },
  "homepage": "https://github.com/tenondecrpc/opencode-agent-monitor#readme",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
